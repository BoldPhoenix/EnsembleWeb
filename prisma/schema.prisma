// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
//  url      = env("DATABASE_URL")
}

model Session {
  id                   String                @id @default(cuid())
  title                String                @default("New Chat")
  skillsScored         Boolean               @default(false)
  createdAt            DateTime              @default(now())
  messages             Message[]
  spans                Span[]
  conversationSummaries ConversationSummary[]
}

model Message {
  id          String         @id @default(cuid())
  role        String
  content     String
  personality String         @default("aimee")
  createdAt   DateTime       @default(now())
  session     Session        @relation(fields: [sessionId], references: [id])
  sessionId   String
  topics      TopicMessage[]
}

model Topic {
  id          String         @id @default(cuid())
  name        String         @unique
  label       String
  category    String         @default("concept")
  summary     String
  characterId String?        // null = shared across all characters
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  messages    TopicMessage[]
}

model TopicMessage {
  topic     Topic   @relation(fields: [topicId], references: [id])
  topicId   String
  message   Message @relation(fields: [messageId], references: [id])
  messageId String

  @@id([topicId, messageId])
}

// ── Tracer ────────────────────────────────────────────────────────────────────
// One row per observable event. Skill scoring and APO both operate on spans.
// kind values: llm_call | tool_use | memory_read | memory_write | skill_match | skill_fire | apo_score

model Span {
  id         String   @id @default(cuid())
  sessionId  String
  traceId    String
  kind       String
  status     String   @default("ok")
  durationMs Int?
  metadata   Json?
  createdAt  DateTime @default(now())
  session    Session  @relation(fields: [sessionId], references: [id])

  @@index([sessionId])
  @@index([kind])
}

// ── Skills ────────────────────────────────────────────────────────────────────
// One row per skill per character. EMA score, lifecycle flags.

model SkillStat {
  id            String    @id @default(cuid())
  skillName     String
  characterId   String    @default("aimee")
  score         Float     @default(0.0)
  trials        Int       @default(0)
  lastFired     DateTime?
  autoGenerated Boolean   @default(false)
  protected     Boolean   @default(false)
  promoted      Boolean   @default(false)
  staleAt       DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([skillName, characterId])
  @@index([characterId])
}

// ── APO ───────────────────────────────────────────────────────────────────────
// Prompt variants generated by APO beam search.
// slot values: character_personality | skill_instructions | tool_guidance

model ApoVariant {
  id       String   @id @default(cuid())
  name     String
  slot     String
  content  String
  score    Float    @default(0.0)
  trials   Int      @default(0)
  active   Boolean  @default(false)
  parentId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name, slot])
  @@index([slot, active])
}

// APO-generated proposals surfaced to user in settings ("How [Name] Grows").
// User accepts/rejects. Auto-accept after 7 days if no action.

model SkillProposal {
  id           String    @id @default(cuid())
  skillName    String
  characterId  String
  oldBody      String
  newBody      String
  reason       String
  accepted     Boolean?  // null = pending, true = accepted, false = rejected
  autoAcceptAt DateTime
  createdAt    DateTime  @default(now())

  @@index([characterId, accepted])
}

// ── Conversation Summaries ────────────────────────────────────────────────────
// Compressed summaries of old messages. Injected before raw messages in context.

model ConversationSummary {
  id          String   @id @default(cuid())
  sessionId   String
  characterId String
  summary     String
  turnStart   Int
  turnEnd     Int
  createdAt   DateTime @default(now())
  session     Session  @relation(fields: [sessionId], references: [id])

  @@index([sessionId, characterId])
}

// ── Character Config ──────────────────────────────────────────────────────────
// Persisted character definitions. Replaces hardcoded personalities.ts in a future phase.
// For now this table exists but personalities.ts is still the source of truth.

// LlmProvider drives which API the chat route dispatches to for this character.
// Each character can run on a different provider — this is Ensemble's multi-model
// killer app. Do NOT collapse this into a single global fallback chain.
enum LlmProvider {
  openrouter
  gemini
  ollama
}

model CharacterConfig {
  id          String      @id @default(cuid())
  name        String      @unique
  basePrompt  String
  avatarModel String      @default("/Aimee.glb")
  voiceLocal  String      @default("Aimee.mp3")
  voiceCloud  String?
  description String
  provider    LlmProvider @default(openrouter)
  llmModel    String?     // null = use provider default / env var
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}
